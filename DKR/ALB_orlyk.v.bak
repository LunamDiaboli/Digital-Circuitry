module ALB_orlyk #(parameter W = 10) (
    input wire clock,
    input wire reset,
    input wire [W-1:0] A_ALB,
    input wire [W-1:0] B_ALB,
    input wire CI,
    input wire [1:0] ALB_MI, // ??????? ??????????????? I4 I3
    output reg [W-1:0] F_ALB,
    output wire CO,
    output wire VO,
    output wire NO,
    output wire ZO
);

    // ?????? ??????? ????????
    reg [W-1:0] RgA;
    reg [W-1:0] RgB;

    // ?????????? ?? ????????? ???, MS (RgA) = S, ? MR (RgB) = R
    wire [W-1:0] S = RgA;
    wire [W-1:0] R = RgB;

    // ????????? ???? ??? ??????????? ???????? (W+1 ??? ??? ?????????? ????????)
    wire [W:0] res_add; 
    wire [W:0] res_sub;
    wire [W-1:0] res_and;
    wire [W-1:0] res_or;

    // ???? ???????????? ????????? ????????????? ?? ?????????
    // 00: R + S + CI
    assign res_add = R + S + CI;

    // 01: S - R - 1 + CI
    assign res_sub = S + ~R + CI;

    // 10: R & S
    assign res_and = R & S;

    // 11: R v S
    assign res_or  = R | S;

    // ????????????? (MX)
    reg [W:0] mux_out;

    always @(*) begin
        case(ALB_MI)
            2'b00: mux_out = res_add;
            2'b01: mux_out = res_sub;
            2'b10: mux_out = {1'b0, res_and}; // ??????? ???????? ?? ???????? ???????
            2'b11: mux_out = {1'b0, res_or};
            default: mux_out = {(W+1){1'b0}};
        endcase
    end

    // ???? ?????????? ????? (? ???????????? ????)
    assign CO = mux_out[W];                                  // ??????? ?? ???? ????????? ?????
    assign NO = mux_out[W-1];                                // ???????? ?????? ??????????
    assign ZO = (mux_out[W-1:0] == {W{1'b0}}) ? 1'b1 : 1'b0; // ???????? ????
    assign VO = NO ^ CO;                                     // ????????????: v = n xor c 

    // ???? ????????????
    reg [W-1:0] norm_out;

    always @(*) begin
        norm_out = mux_out[W-1:0]; // ?? ????????????? ????????? ????????? ??? ????
        
        // ???????????, ?? ?? ??????????? ???????? (????????? '00' ??? ?????????? '01') 
        // ?? ?? ??????? ???????????? (VO == 1)
        if ((ALB_MI == 2'b00 || ALB_MI == 2'b01) && VO) begin
            // ???????????? ???????? (???? ?? 1 ??????).
            // ????? ???????? ???????? ???? ??????? (CO), ? ????? ??????? ?????????? ??????.
            norm_out = {CO, mux_out[W-1:1]}; 
        end
    end

    // ???????? ???????? ??????? RgF
    always @(posedge clock or posedge reset) begin
        if (reset) begin
            RgA <= 0;
            RgB <= 0;
            F_ALB <= 0;
        end else begin
            RgA <= A_ALB;
            RgB <= B_ALB;
            F_ALB <= norm_out; // ????????? ?????????????? ????????? ? ???????
        end
    end

endmodule
