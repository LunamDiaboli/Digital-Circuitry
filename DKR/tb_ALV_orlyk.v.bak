`timescale 1ns / 1ps

module tb_ALB_orlyk;

    parameter W = 10;
    
    reg clock;
    reg reset;
    reg [W-1:0] A_ALB;
    reg [W-1:0] B_ALB;
    reg CI;
    reg [1:0] ALB_MI;
    
    wire [W-1:0] F_ALB;
    wire CO, VO, NO, ZO;

    // ????????????? ??????
    Mega_Lab_ALB #(.W(W)) uut (
        .clock(clock),
        .reset(reset),
        .A_ALB(A_ALB),
        .B_ALB(B_ALB),
        .CI(CI),
        .ALB_MI(ALB_MI),
        .F_ALB(F_ALB),
        .CO(CO),
        .VO(VO),
        .NO(NO),
        .ZO(ZO)
    );

    // ????????? ????????? ???????
    always #5 clock = ~clock;

    initial begin
        // ????????? ????????
        clock = 0;
        reset = 1;
        A_ALB = 0;
        B_ALB = 0;
        CI = 0;
        ALB_MI = 0;

        #10 reset = 0;

        // ???? 1: ???????? ????????? 00 (R + S + CI) ??? S1 = A1 + B1
        // ???????? ? ?????????: A1 = 0110001110, B1 = 1010010111
        A_ALB = 10'b0110001110; 
        B_ALB = 10'b1010010111; 
        CI = 0;
        ALB_MI = 2'b00; 
        
        // ??????? ??? ?????: ???? ??? ?????? ? RgA/RgB, ?????? ??? ?????? ? F_ALB
        #20; 
        
        // ???? 2: ???????? ????????? ? (R & S)
        ALB_MI = 2'b10;
        #20;

        // ???? 3: ???????? ????????? ??? (R \/ S)
        ALB_MI = 2'b11;
        #20;
        
        // ?????????? ?????????
        $finish;
    end
    
    // ????? ??????????? ? ???????
    initial begin
        $monitor("???=%0t | MI=%b | A=%b, B=%b | F_ALB=%b | CO=%b, VO=%b, NO=%b, ZO=%b", 
                 $time, ALB_MI, A_ALB, B_ALB, F_ALB, CO, VO, NO, ZO);
    end

endmodule