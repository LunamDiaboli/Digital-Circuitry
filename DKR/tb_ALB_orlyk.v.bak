        .clock(clock),
        .reset(reset),
        .A_ALB(A_ALB),
        .B_ALB(B_ALB),
        .CI(CI),
        .ALB_MI(ALB_MI),
        .F_ALB(F_ALB),
        .CO(CO),
        .VO(VO),
        .NO(NO),
        .ZO(ZO)
    );

    // ????????? ????????? ???????? (clock)
    always #5 clock = ~clock;

    initial begin
        // 1. ?????????? ???? ?? ???????? (Reset)
        clock = 0;
        reset = 1;
        A_ALB = 0;
        B_ALB = 0;
        CI = 0;
        ALB_MI = 0;

        #10 reset = 0;

        // ???? 1: S1 = A1 + B1 (?????????, ALB_MI = 00)
        // ??? ????????? ???????????? (VO=1) ? ????????????
        A_ALB  = 10'b0110001110; // A1
        B_ALB  = 10'b1010010111; // B1
        CI     = 0;
        ALB_MI = 2'b00; 
        #20; 
        
        // ???? 2: S2 = A1 + B2 (?????????, ALB_MI = 00)
        A_ALB  = 10'b0110001110; // A1
        B_ALB  = 10'b0101101001; // B2 ? ????????????? ????
        CI     = 0;
        ALB_MI = 2'b00;
        #20;

        // ???? 3: D1 = A1 - B1 (??????????, ALB_MI = 01)
        // ????????: S - R - 1 + CI. ??? ???????? S - R, ??????? CI = 1.
        A_ALB  = 10'b0110001110; // A1
        B_ALB  = 10'b1010010111; // B1
        CI     = 1;              
        ALB_MI = 2'b01;
        #20;

        // ???? 4: R & S (??????? ?, ALB_MI = 10)
        A_ALB  = 10'b1111000011; 
        B_ALB  = 10'b1010101010; 
        CI     = 0;
        ALB_MI = 2'b10;
        #20;

        // ???? 5: R \/ S (??????? ???, ALB_MI = 11)
        A_ALB  = 10'b1100001100; 
        B_ALB  = 10'b0011110011; 
        ALB_MI = 2'b11;
        #20;
        
        // ?????????? ?????????
        $finish;
    end

    // ????? ??????????? ? ???????? ??????? (Transcript)
    initial begin
        $monitor("Time=%0t | MI=%b | A=%b, B=%b | F_ALB=%b | CO=%b, VO=%b, NO=%b, ZO=%b", 
                 $time, ALB_MI, A_ALB, B_ALB, F_ALB, CO, VO, NO, ZO);
    end

endmodule